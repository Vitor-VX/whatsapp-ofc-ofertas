{
  "name": "whatsapp-pet-art-funnel",
  "version": "1.0.0",
  "description": "WhatsApp sales funnel engine for personalized pet art digital product",
  "main": "dist/app.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "worker": "node dist/worker.js",
    "dev": "ts-node src/app.ts",
    "dev:worker": "tsc && node dist/worker.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src"
  },
  "keywords": [
    "whatsapp",
    "funnel",
    "sales",
    "chatbot",
    "automation",
    "pet-art",
    "stripe",
    "gemini"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.967.0",
    "@google/genai": "^1.44.0",
    "amqplib": "^0.10.3",
    "axios": "^1.5.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "file-type": "^20.5.0",
    "fluent-ffmpeg": "^2.1.2",
    "mercadopago": "^2.12.1",
    "mongoose": "^7.5.0",
    "qrcode": "^1.5.4",
    "redis": "^4.6.10",
    "stripe": "^13.3.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/fluent-ffmpeg": "^2.1.1",
    "@types/node": "^20.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.48.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.22.1",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
